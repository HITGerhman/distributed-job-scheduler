ETCD_ENDPOINTS=http://etcd:2379
ETCD_DIAL_TIMEOUT=5s
LEADER_ELECTION_KEY=/masters/leader
MASTER_LEASE_TTL=5
WORKER_DISCOVERY_PREFIX=/workers/
WORKER_ADVERTISE_ADDR=worker:50051
WORKER_LEASE_TTL=10
MASTER_REPORT_TIMEOUT=12s
