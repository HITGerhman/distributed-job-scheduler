APP_ENV=development
LOG_LEVEL=info

MASTER_ADDR=master-1:8080
MASTER_PORT=8080
MASTER_ID=master-1
MASTER_ADVERTISE_HTTP_ADDR=master-1:8080
MASTER_ADVERTISE_GRPC_ADDR=master-1:50052
MASTER_GRPC_ADDRS=master-1:50052,master-2:50052,master-3:50052

WORKER_ID=worker-1
